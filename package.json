{
  "name": "@helix/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Agent orchestration loop system built on pi",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "helix": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/server/public dist/server/",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.80.3",
    "@earendil-works/pi-ai": "^0.80.3",
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "express": "^5.2.1",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
