{
  "extensions": { "enabled": false },
  "repoContext": { "enabled": true },
  "deliverable": { "pr": false },
  "orchestrator": {
    "workflow": ["planner", "dev", "verifier"],
    "maxIterations": 6
  },
  "triggers": {
    "github": {
      "repo": "acme/widget",
      "labelFilter": "helix",
      "mode": "poll",
      "intervalSec": 60
    }
  },
  "mergeGate": {
    "autoMerge": true,
    "maxDiffLines": 300,
    "maxFiles": 10,
    "requireVerifierPass": true
  }
}
